<?xml version="1.0" encoding="utf-8"?>
<mujoco model="combined_robots">
    <!-- 编译器设置 -->
    <compiler angle="radian" meshdir="assets" texturedir="assets" autolimits="true" eulerseq="xyz"/>
    
    <!-- 视觉设置 -->
    <visual>
        <headlight diffuse="0.8 0.8 0.8" ambient="0.5 0.5 0.5" specular="0 0 0"/>
        <rgba haze="0.15 0.25 0.35 1"/>
        <global azimuth="140" elevation="-30"/>
    </visual>

    <!-- 选项设置 -->
    <option>
        <flag contact="disable"/>
    </option>

    <!-- 资源定义 -->
    <asset>
        <!-- 地面纹理 -->
        <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
        markrgb="0.8 0.8 0.8" width="300" height="300"/>
        <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
        
        <!-- 装配机械臂的网格 -->
        <mesh name="arm0_link" content_type="model/stl" file="arm0_link.STL"/>
        <mesh name="arm1_link" content_type="model/stl" file="arm1_link.STL"/>
        <mesh name="arm2_link" content_type="model/stl" file="arm2_link.STL"/>
        <mesh name="arm3_link" content_type="model/stl" file="arm3_link.STL"/>
        <mesh name="arm4_link" content_type="model/stl" file="arm4_link.STL"/>
        <mesh name="arm5_link" content_type="model/stl" file="arm5_link.STL"/>
        <mesh name="arm6_link" content_type="model/stl" file="arm6_link.STL"/>
        <mesh name="cube_wheel" content_type="model/stl" file="wheel_link.STL"/>

        <!-- 模块化机器人的网格 -->
        <mesh name="body" file="cube_base.STL"/>
        <mesh name="cube_shell" file="cube_shell.STL"/>
        <mesh name="cube_motor" file="cube_motor.STL"/>
    </asset>

    <!-- 默认类定义 -->
    <default>
        <!-- 装配机械臂的默认设置 -->
        <default class="visual">
            <geom contype="0" conaffinity="0" group="1" type="mesh"/>
        </default>
        <default class="collision">
            <geom contype="1" conaffinity="1" group="1" type="mesh" rgba="0.5 0.6 0.7 0.5"/>
        </default>
        
        <!-- 模块化机器人的默认设置 -->
        <default class="free_box">
            <geom type="box" size="0.06 0.06 0.06" pos="0 0 0" mass="0.0" contype="0" conaffinity="0" rgba="0 0 0 0"/>
        </default>
        <default class="base_body">
            <geom type="mesh" mesh="body" pos="0.0055426 0.056 -0.01" mass="0.5" contype="0" conaffinity="0" rgba="0.2 0.2 0.2 1"/>
        </default>
        <default class="hinge_body">
            <geom type="box" size="0.06 0.06 0.06" pos="0 0 0" mass="0.5" contype="0" conaffinity="0" rgba="0.2 0.8 0.2 1"/>
        </default>
        <default class="hinge_motor_body">
            <geom type="box" size="0.03 0.03 0.03" pos="0 0 0" mass="0.5" rgba="0.2 0.8 0.2 1" contype="0" conaffinity="0"/>
        </default>
        <default class="wheel_body">
            <geom type="mesh" mesh="body" pos="-0.06 -0.06 -0.06" mass="0.5" rgba="0.2 0.2 0.8 1" contype="0" conaffinity="0"/>
        </default>
        <default class="drone_body">
            <geom type="mesh" mesh="body" pos="-0.06 -0.06 -0.06" mass="0.5" rgba="0.3 0.6 0.9 1" contype="0" conaffinity="0"/>
        </default>
        <default class="end_coll">
            <geom type="box" size="0.06 0.06 0.06" pos="0 0 0" mass="0.5" contype="0" conaffinity="1" rgba="0.8 0.2 0.2 0.8" friction="0.6"/>
        </default>
        <default class="hinge_coll">
            <geom type="box" size="0.06 0.06 0.06" pos="0 0 0" mass="0.5" contype="0" conaffinity="0" rgba="0 0 0 0"/>
        </default>
        <default class="wheel_coll">
            <geom type="box" size="0.06 0.06 0.06" pos="0 0 0" mass="0.5" contype="0" conaffinity="1" rgba="0 0 0 0"/>
