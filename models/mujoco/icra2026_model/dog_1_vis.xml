        <default class="wheel+y">
            <joint type="hinge" axis="0 1 0" pos="0 0 0"/>
        </default>
        <default class="wheel-y">
            <joint type="hinge" axis="0 1 0" pos="0 0 0"/>
        </default>
    </default>

