        </default>
    </default>

    <!-- 关节默认设置 -->
    <default>
        <joint type="hinge" damping="0.1"/>
        
        <default class="joint+y">
            <joint type="hinge" axis="0 1 0" pos="0 0 0" damping="0.1" armature="0.01"/>
        </default>
        <default class="joint-y">
            <joint type="hinge" axis="0 1 0" pos="0 0 0" damping="0.1" armature="0.01"/>
        </default>
        <default class="joint+x">
