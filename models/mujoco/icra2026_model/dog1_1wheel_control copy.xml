<?xml version="1.0" encoding="utf-8"?>
<mujoco model="modular_robot">
    <compiler angle="radian" meshdir="assets" texturedir="assets" autolimits="true"/>
    <option gravity="0 0 -9.81"/>
    <statistic center="0 0 0.1" extent="0.6"/>
    <visual>
        <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
        <rgba haze="0.15 0.25 0.35 1"/>
        <global azimuth="140" elevation="-30"/>
    </visual>
    <asset>
        <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
        <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" width="300" height="300"/>
        <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    </asset>
    <default>
        <default class="base_collision">
            <geom type="box" size="0.06 0.06 0.06" pos="0 0 0" mass="0.5" contype="0" conaffinity="0" rgba="0.8 0.2 0.2 0.3"/>
        </default>
        <default class="end_collision">
            <geom type="box" size="0.06 0.06 0.06" pos="0 0 0" mass="0.5" contype="0" conaffinity="1" rgba="0.8 0.2 0.2 0.3" friction="0.6" />
        </default>  
        <default class="wheel_collision">
            <geom type="box" size="0.06 0.06 0.06" pos="0 0 0" mass="0.5" contype="0" conaffinity="0" rgba="0.2 0.8 0.2 0.3"/>
        </default>
        <default class="wheel_tire_collision">
            <geom type="cylinder" size="0.1 0.03" pos="0 0 0" mass="0.5" quat="0 0 0.707 0.707" contype="0" conaffinity="1" rgba="0.2 0.8 0.2 0.3" friction="1.0"/>
        </default>
        <default class="wheel">
            <joint type="hinge" axis="0 1 0" pos="0 0 0"  limited="false" />
        </default>
        <default class="joint_motor">
            <motor ctrlrange="-100 100"/>
        </default>
        <default class="wheel_velocity">
            <position kv="10" forcelimited="true" forcerange="-500 500"/>
        </default>
    </default>

    <worldbody>
        <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
        <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>
        <body name="module1" pos="0 0 0.1">
            <freejoint/>
            <geom class="base_collision"/>
            <body name="module2" pos="0.12 0 0">
                <geom class="base_collision"/>
                <body name="wheel1" pos="0 0.12 0">
                    <geom class="wheel_collision"/>
                    <geom class="wheel_tire_collision"/>
                    <joint class="wheel" name="wheel1_joint"/>
                </body>
                <body name="wheel2" pos="0 -0.12 0">
                    <geom class="wheel_collision"/>
                    <geom class="wheel_tire_collision"/>
                    <joint class="wheel" name="wheel2_joint"/>  
                </body>
            </body>
            <body name="module3" pos="-0.12 0 0">
                <geom class="base_collision"/>
                <body name="wheel3" pos="0 0.12 0">
                    <geom class="wheel_collision"/>
                    <geom class="wheel_tire_collision"/>
                    <joint class="wheel" name="wheel3_joint"/>
                </body>
                <body name="wheel4" pos="0 -0.12 0">
                    <geom class="wheel_collision"/>
                    <geom class="wheel_tire_collision"/>
                    <joint class="wheel" name="wheel4_joint"/>
                </body>
            </body>
        </body>
    </worldbody>

    <actuator>

        <position name="wheel1" joint="wheel1_joint" class="wheel_velocity"/>
        <position name="wheel2" joint="wheel2_joint" class="wheel_velocity"/>
        <position name="wheel3" joint="wheel3_joint" class="wheel_velocity"/>
        <position name="wheel4" joint="wheel4_joint" class="wheel_velocity"/>

    </actuator>

</mujoco>